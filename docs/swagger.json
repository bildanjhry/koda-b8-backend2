                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/lib.Response"
                        }
                    }
                }
            }
        },
        "/user/all": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "get all users",
                "tags": [
                    "users"
                ],
                "summary": "Show all users",
                "parameters": [
                    {
                        "type": "string",
                        "description": "page",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "limit",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "search users by name",
                        "name": "search[name]",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "search users by email",
                        "name": "search[email]",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
